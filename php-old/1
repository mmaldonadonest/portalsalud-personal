    { inputId: "#DIFRESP", value: $("#DIFRESP0").val() },
    { inputId: "#DOLARDGARG", value: $("#DOLARDGARG0").val() },
    { inputId: "#ESCURRINAZ", value: $("#ESCURRINAZ0").val() },
    { inputId: "#OJOSROJOS", value: $("#OJOSROJOS0").val() },
    { inputId: "#DOLMUSART", value: $("#DOLMUSART0").val() },
  ];
  fields.forEach(function (field) {
    var checkedValue = field.value == 1 ? true : false;
