function downloadPDFCons(idSess) {
  // Cadena Base64 del archivo PDF
  var base64String = $("#text" + idSess).val();

  // Obtener el tipo MIME del archivo PDF (opcional)
  var mimeType = "application/pdf";

  // Convertir la cadena Base64 a un arreglo de bytes
  var byteCharacters = atob(base64String);
  var byteNumbers = new Array(byteCharacters.length);
  for (var i = 0; i < byteCharacters.length; i++) {
    byteNumbers[i] = byteCharacters.charCodeAt(i);
  }
  var byteArray = new Uint8Array(byteNumbers);

  // Crear el objeto Blob a partir del arreglo de bytes
  var blob = new Blob([byteArray], { type: mimeType });

  // Crear una URL del objeto Blob
  var url = URL.createObjectURL(blob);

  // Crear un enlace de descarga para el archivo PDF
  var link = document.createElement("a");
  link.href = url;
  link.download = "archivo.pdf";

  // Agregar el enlace al documento y hacer clic en él para descargar el archivo
  document.body.appendChild(link);
  link.click();

  // Liberar la URL del objeto Blob
  var urlDown = URL.revokeObjectURL(url);

  console.log(urlDown);
}

