function generarExcelIncapa() {
  var ini = $("#fechaInINI").val();
  var fini = $("#fechaInFINI").val();
  if (ini && fini) {
    $.ajax({
      type: "POST",
      url: "rest/dashboard/generarExcelIncapa.php",
      data: { ini: ini, fini: fini },
      dataType: "json",
      success: function (response) {
        if (response) {
          console.log(response);
          const ws = XLSX.utils.json_to_sheet(response.Datos);
          const wb = XLSX.utils.book_new();
          XLSX.utils.book_append_sheet(wb, ws, "Datos");
          XLSX.writeFile(wb, "Datos.xlsx");
        } else {
          Swal.fire({
            title: "Información",
            text: "No se encontraron datos disponibles.",
            icon: "question",
          });
        }
      },
    });
  } else {
    Swal.fire({
      title: "Error",
      text: "Debe indicar un rango de fechas válidas.",
      icon: "error",
    });
  }
}
