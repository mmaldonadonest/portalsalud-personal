function viewExpedHeredoFam(type) {
  let numero = $("#mostrador").val();
  //console.log(numero);
  $("#loadingData2").show();
  var nss = $("#inputSearchData").val();
  $("#" + type + "BTN").removeAttr("onclick");
  $("#" + type + "BTN2").hide();
  $("#" + type + "BTN").addClass("btn-dark");
  /*  $("#" + type + "BTN2").addClass("disabled text-info"); */
$.ajaxSetup({
    cache: true
});
  $.ajax({
    type: "POST",
    url: "rest/dashboard/viewTypeExped.php",
    headers: {
        'Connection': 'keep-alive'
    },	  
    data: { data: type, nss: nss },
    dataType: "html",
    success: function (response) {
      numero++;
      mostrador.value = numero;
      $("#viewHeredoSec").append(response);
      $("#chargeIcdIcon").hide();
      //console.log(type);
      setTimeout(chackValues, 1000, type);
      $("#loadingData2").hide();
      var textAreas = document.querySelectorAll("textarea");
      textAreas.forEach(function (textArea) {
        textArea.addEventListener("input", function () {
          if (textArea.value.length > 500) {
            textArea.value = textArea.value.substring(0, 500);
          }
        });
      });
    },
  });
}
