function calcularSalario() {
  function calcularPagoIncapacidad(
    tipoIncapacidad,
    diasIncapacidad,
    salarioDiario
  ) {
    let pagoTotal = 0;

    if (tipoIncapacidad === "enfermedad general") {
      cambioFechaInc(diasIncapacidad);
      const valorOriginal = salarioDiario;

      // Calcular el 60% del valor original
      const sesentaPorCiento = valorOriginal * 0.6;
      const salarioMinimoDiario = sesentaPorCiento;
      const diasPagarAl60PorCiento = 4;
      const diasPagarAl100PorCiento = 10;

      if (diasIncapacidad >= diasPagarAl60PorCiento) {
        pagoTotal = Math.max(diasIncapacidad * salarioMinimoDiario);
      } else {
        pagoTotal = 0;
      }
    } else if (
      tipoIncapacidad === "accidente trayecto" ||
      tipoIncapacidad === "accidente laboral" ||
      tipoIncapacidad === "maternidad"
    ) {
      cambioFechaInc(diasIncapacidad);
      pagoTotal = diasIncapacidad * salarioDiario;
    } else {
      console.log("Tipo de incapacidad no válido");
    }

    return pagoTotal;
  }

  // Ejemplo de uso:
  traerDias();
  setTimeout(function () {
    const salarioDiario = $("#SalIntegrInp").val();
    const diasIncapacidad = $("#DiasAutInp").val();
    const tipo = $("#ramoInp").val();
    var comSal = $("#rubroInput").val();
    var salarioAjustado = salarioDiario * diasIncapacidad;
    var salarioAcomu = parseFloat($("#salarioAcomuIn").val());
    var diasAcumuladas = parseFloat($("#diasAcumuladosInp").val());
    var nuevosDias = parseFloat(diasIncapacidad);
    $("#diasAcumuladosInp").val(nuevosDias + diasAcumuladas);
    if (tipo == "enfermedad_general") {
      const pagoEnfermedadGeneral = calcularPagoIncapacidad(
        "enfermedad general",
        diasIncapacidad,
        salarioDiario
      );
      var pagonuevo = parseFloat(pagoEnfermedadGeneral);
      $("#CostoInp").val(pagoEnfermedadGeneral);
      var nuevoAcomu = pagonuevo + salarioAcomu;

      $("#salarioAcomuIn").val(nuevoAcomu);
      if (comSal === "Interna") {
        $("#ComplSalaInp").val(salarioAjustado);
      }
    } else {
      const pagoAccidenteMaternidad = calcularPagoIncapacidad(
        "maternidad",
        diasIncapacidad,
        salarioDiario
      );
      var pagonuevo = parseFloat(pagoAccidenteMaternidad);
      $("#CostoInp").val(pagoAccidenteMaternidad);
      var nuevoAcomu = pagonuevo + salarioAcomu;
      $("#salarioAcomuIn").val(nuevoAcomu);
      if (comSal === "Interna") {
        $("#ComplSalaInp").val(salarioAjustado);
      }
    }
  }, 1000);
}

function cambioFechaInc(dias) {
  // Obtener la fecha inicial
  var fechaInicial;
  if ($("#fechainiInp").val()) {
    fechaInicial = new Date($("#fechainiInp").val());
  } else {
    fechaInicial = new Date($("#fechainiInpINI").val());
  }

  // Sumar días
  fechaInicial.setDate(fechaInicial.getDate() + (dias - 1));

  // Formatear la fecha en el formato YYYY-MM-DD
  const fechaFinal = fechaInicial.toISOString().split("T")[0];

  // Establecer la fecha final en el campo de fecha final
  $("#fechaTermInp").val(fechaFinal);

  console.log(fechaFinal);
}
